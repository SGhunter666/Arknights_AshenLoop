[gd_resource type="Resource" script_class="EventData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/EventData.gd" id="1"]

[resource]
script = ExtResource("1")
id = "doctor_reflection"
title = "博士的回声"
body = "博士之前的回答被记录在行动日志里。现在，同样的问题以更具体的形式回来了。不是哲学，而是一条必须执行的战术路线。

前方小队遭遇伏击，需要增援方案。你的选择会和之前的倾向产生共鸣；如果一致，效果会更强。"
conditions = PackedStringArray("any:doctor_ideal,doctor_efficiency,doctor_burden")
options = Array[Dictionary]([{
"label": "治疗优先方案",
"effects": Array[Dictionary]([{
"type": "heal",
"amount": 15
}, {
"type": "add_card",
"card_id": "medical_evac_route"
}, {
"type": "set_flag",
"flag": "support_upgrade_credit"
}]),
"effects_exusiai": Array[Dictionary]([{
"type": "heal",
"amount": 12
}, {
"type": "add_card",
"card_id": "ex_u19_pl_cover_screen"
}, {
"type": "set_flag",
"flag": "support_upgrade_credit"
}]),
"reward_cards": PackedStringArray("rescue_corridor", "stabilize_line"),
"reward_cards_exusiai": PackedStringArray("ex_c25_pl_supply_drop", "ex_u22_air_cover"),
"result": "治疗方案稳住了小队。如果你之前选择了理想路线，这次的共鸣会让支援链路更容易拉满。"
}, {
"label": "精确打击方案",
"effects": Array[Dictionary]([{
"type": "add_card",
"card_id": "precise_break"
}, {
"type": "set_flag",
"flag": "legendary_offer_next_reward"
}, {
"type": "set_flag",
"flag": "next_battle_enemy_strength"
}]),
"effects_exusiai": Array[Dictionary]([{
"type": "add_card",
"card_id": "ex_c10_precision_puncture"
}, {
"type": "set_flag",
"flag": "legendary_offer_next_reward"
}, {
"type": "set_flag",
"flag": "next_battle_enemy_strength"
}]),
"reward_cards": PackedStringArray("final_directive", "last_argument"),
"reward_cards_exusiai": PackedStringArray("ex_r09_terminal_lock", "ex_u11_headline_rhythm"),
"result": "伏击被迅速粉碎，但敌方也注意到了你的攻击模式。下一份奖励更容易出传奇选项，但下一场战斗也更难。"
}, {
"label": "全力突围方案",
"effects": Array[Dictionary]([{
"type": "lose_hp",
"amount": 8
}, {
"type": "add_card",
"card_id": "pain_for_power"
}, {
"type": "add_card",
"card_id": "burn_will"
}, {
"type": "set_flag",
"flag": "double_next_reward"
}]),
"effects_exusiai": Array[Dictionary]([{
"type": "lose_hp",
"amount": 8
}, {
"type": "add_card",
"card_id": "ex_c17_burst_order"
}, {
"type": "add_card",
"card_id": "ex_c22_rapid_reload"
}, {
"type": "set_flag",
"flag": "double_next_reward"
}]),
"reward_cards": PackedStringArray("crisis_surge", "reckless_invocation"),
"reward_cards_exusiai": PackedStringArray("ex_r14_endless_chain", "ex_u17_combo_rhythm", "ex_r11_angelic_storm"),
"result": "你用最激烈的方式打开了突破口。队伍付出了代价，但下一份奖励会因此更加丰厚。"
}])
