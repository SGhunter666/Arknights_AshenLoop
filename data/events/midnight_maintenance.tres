[gd_resource type="Resource" script_class="EventData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/EventData.gd" id="1"]

[resource]
script = ExtResource("1")
id = "midnight_maintenance"
title = "深夜整备"
body = "夜里，安全屋只剩工具碰撞和低声报数。有人修通讯，有人补护甲，有人把白天来不及处理的卡牌记录重新分类。\n\n这段时间不长，但够做一项整备：换护符、处理引导升级，或者接入一个小型回声模块。"
options = Array[Dictionary]([{
"label": "更换护符准备",
"effects": Array[Dictionary]([{"type": "add_charm", "charm_id": "operators_thread"}]),
"reward_cards": PackedStringArray(),
"effects_exusiai": Array[Dictionary]([{"type": "add_charm", "charm_id": "ex_h04_delivery_badge"}]),
"reward_cards_exusiai": PackedStringArray("ex_c27_team_callout"),
"result": "新的护符被系在装备带上。它不显眼，但会在之后替你省下一点麻烦。"
}, {
"label": "升级引导牌路线",
"effects": Array[Dictionary]([{"type": "set_flag", "flag": "channel_upgrade_credit"}]),
"reward_cards": PackedStringArray("channel_pulse","unstable_channel"),
"effects_exusiai": Array[Dictionary]([{"type": "set_flag", "flag": "support_upgrade_credit"}]),
"reward_cards_exusiai": PackedStringArray("ex_u03_reload_plan", "ex_u22_air_cover"),
"result": "引导相关记录被单独标出。后续升级时，这条路线会更容易被找到。"
}, {
"label": "拿走回声别针",
"effects": Array[Dictionary]([{"type": "add_module", "module_id": "echo_pin"}]),
"reward_cards": PackedStringArray(),
"effects_exusiai": Array[Dictionary]([{"type": "add_module", "module_id": "ex_m03_fast_feeder"}]),
"reward_cards_exusiai": PackedStringArray("ex_c25_pl_supply_drop"),
"result": "回声别针接入终端。下一次触发第一段回声时，它会顺手带来额外抽牌。"
}])
