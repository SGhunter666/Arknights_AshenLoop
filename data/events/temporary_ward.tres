[gd_resource type="Resource" script_class="EventData" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/EventData.gd" id="1"]

[resource]
script = ExtResource("1")
id = "temporary_ward"
title = "临时隔离病房"
body = "一间破碎的店面被临时改造成病房。撕裂的帘布、便携灯和一排排药剂摆在箱子上，像整齐摆放就能变出更多补给。

这里有被恐慌波及的平民，也有仍可能重返战线的罗德岛干员。小队必须决定药品的去向：稳定病房，平均分配，还是把药留给下一场前线冲突。

没有一个选择是干净的。只是有些代价现在显现，有些代价会在后面追上来。"
options = Array[Dictionary]([{
"label": "花费 20 金币稳定病房",
"effects": Array[Dictionary]([{
"type": "lose_gold",
"amount": 20
}, {
"type": "set_flag",
"flag": "accept_burden_1"
}]),
"reward_cards": PackedStringArray("discipline_note","tactical_calm"),
"reward_cards_exusiai": PackedStringArray("ex_c25_pl_supply_drop","ex_c27_team_callout"),
"result": "病房的灯又多亮了一会儿。今晚少了一些失去的声音，小队记住了自己先选择了保护。"
}, {
"label": "平均分配药品",
"effects": Array[Dictionary]([{
"type": "set_flag",
"flag": "enemy_hp_bonus_1"
}]),
"reward_cards": PackedStringArray("pulse_scan","focus_pulse"),
"reward_cards_exusiai": PackedStringArray("ex_u03_reload_plan","ex_c14_tagged_signal"),
"result": "你把短缺平均分摊给每个人，买到的是时间，而不是确定。下一场战斗会带着这个妥协继续前进。"
}, {
"label": "把药留给前线",
"effects": Array[Dictionary]([{
"type": "add_card",
"card_id": "hesitation"
}, {
"type": "add_module",
"module_id": "signal_booster"
}]),
"effects_exusiai": Array[Dictionary]([{
"type": "add_card",
"card_id": "hesitation"
}, {
"type": "add_module",
"module_id": "ex_m11_storm_permit"
}]),
"reward_cards": PackedStringArray("burn_will"),
"reward_cards_exusiai": PackedStringArray("ex_c17_burst_order", "ex_c22_rapid_reload"),
"result": "前线拿到了需要的东西，小队状态立刻变得更尖锐。代价很难命名，只像一阵沉默落进牌组。"
}])
